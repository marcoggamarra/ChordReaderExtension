{
  "manifest_version": 3,
  "name": "My First Extension",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "tabCapture", "offscreen"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:8765/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "index.html" }
}